# ─────────────────────────────────────────────────────────────────────────────
# Soft Landing — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# See docs/CREDENTIALS.md for step-by-step instructions on getting each key.
# ─────────────────────────────────────────────────────────────────────────────

# App environment
EXPO_PUBLIC_APP_ENV=development   # development | staging | production

# ── RevenueCat (Subscriptions) ────────────────────────────────────────────────
# Get from: https://app.revenuecat.com → Project → API Keys
# Required for premium tier ($4.99/mo, $34.99/yr) to function.
# Without these the app always runs as free tier.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=

# ── Firebase (V2 — cloud sync, optional) ─────────────────────────────────────
# Get from: https://console.firebase.google.com → Project Settings → Your apps
# Not used in V1. Uncomment when adding cloud sync in V2.
# EXPO_PUBLIC_FIREBASE_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXX
# EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=soft-landing.firebaseapp.com
# EXPO_PUBLIC_FIREBASE_PROJECT_ID=soft-landing
# EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=soft-landing.appspot.com
# EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
# EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:ios:xxxxxxxxxxxx

# ── Notes ─────────────────────────────────────────────────────────────────────
# Variables prefixed EXPO_PUBLIC_ are bundled into the client binary.
# Never put private server-side secrets with this prefix.
# Store Apple/Google signing credentials in eas.json (never committed).
