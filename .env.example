# ─── RevenueCat ───────────────────────────────────────────────────────────────
# REQUIRED for subscription features on each platform
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# ─── App Environment ──────────────────────────────────────────────────────────
# Controls feature flags and logging verbosity
# Values: development | staging | production
EXPO_PUBLIC_APP_ENV=development

# ─── Future (V2+) — not needed for MVP ───────────────────────────────────────
# EXPO_PUBLIC_API_URL=          # Cloud sync backend URL
# EXPO_PUBLIC_SENTRY_DSN=       # Error monitoring
# EXPO_PUBLIC_ANALYTICS_KEY=    # Analytics (requires user consent disclosure)

# NOTE: Variables prefixed with EXPO_PUBLIC_ are bundled into the client.
# Never put secrets or private keys with this prefix.
# Server-side secrets go in a separate .env file that is never committed.
